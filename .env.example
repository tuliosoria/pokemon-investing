# AWS / Amplify runtime
AWS_REGION=us-east-1
DYNAMODB_TABLE=pokeinvest-cache

# Provider credentials
# Optional: only needed for one-time PokeData backfills or live population enrichment
POKEDATA_API_KEY=
PRICECHARTING_API_TOKEN=

# Sealed ML runtime
# auto    -> prefer published DynamoDB models, fall back to bundled JSON artifacts
# bundled -> ignore published DynamoDB models and force the repo-bundled rollback copy
SEALED_ML_MODEL_SOURCE=auto

# Sealed ML retrainer
# false lets you capture outcomes and retrain without publishing new model chunks
SEALED_ML_PUBLISH_ENABLED=true
# Optional local override for retraining output artifacts
SEALED_ML_OUTPUT_DIR=src/lib/data/sealed-ml
